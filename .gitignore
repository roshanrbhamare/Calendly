# .gitignore - Never commit sensitive files

# Environment variables (local only)
.env
.env.local
.env.*.local

# Dependencies
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# Build outputs
dist/
build/
.next/
out/

# Development
.DS_Store
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# IDE
.vscode/
.idea/
*.swp
*.swo
*.vim

# OS
Thumbs.db
.DS_Store

# Testing
coverage/
.nyc_output/

# Temporary
tmp/
temp/

# Lock files (if using npm/yarn at project root, keep these in respective folders)
# But generally, commit lock files for consistency
